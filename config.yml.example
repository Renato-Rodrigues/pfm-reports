# PFM Reports Configuration Example
# Copy this file to "config.yml" and customize it to match your system's local paths.
# "config.yml" is gitignored and will be used by the run scripts and reports if no explicit arguments are passed.

# madrat data-cache folder — the madrat::setConfig(cachefolder=) the compute layer reads
# inputs from (CarbonPrice, EDGAR, PE/FE, Ember, V-Dem, SSP2). Relative paths resolve against
# the working directory. (Legacy key name: `cacheDir` — still accepted by start.R.)
cachefolder: "data/cache"

# Policy Scenario Registry (ADR 0035) — the REMIND policy pathways the one shared Fitted
# Model is projected onto. Each entry: stable `id`, human-readable `name` (reports + paper),
# `gdx` path, and `gdxRegionMapping` matching the gdx's native resolution (default H12 runs
# use regionmappingH12.csv; EU21 runs use regionmapping_21_EU11-without-missingH12.csv).
# `gatingScenario` names the scenario whose projection drives model selection (the
# high-ambition stress test). Selection runs once against it; every scenario is projected.
scenarios:
  - id: national-policies
    name: "National Policies"
    gdx: "data/runs/<NPi-run>/fulldata.gdx"
    gdxRegionMapping: "regionmappingH12.csv"
  - id: climate-ambition
    name: "Climate Ambition"
    gdx: "data/runs/<PkBudg-run>/fulldata.gdx"
    gdxRegionMapping: "regionmappingH12.csv"
gatingScenario: climate-ambition

# Legacy single-scenario fallback (used only when `scenarios:` is absent).
gdxPath: "data/fulldata.gdx"

# Fit Cache / model store (ADR 0009) — holds models/, panels/ and index.json. This is the
# `modelDir` argument of the pfm run* functions (distinct from the madrat `cachefolder` above).
modelDir: "output"

# Results Root (ADR 0018): the compute layer (pfm) writes curated artifacts here —
# sweep.rds, selected-models.yml, robustness.rds, temporal-split.rds, subnational.rds,
# manifest.json — organised into named Run-Groups <resultsDir>/<group>/. The reports read here.
resultsDir: "output"

# Active Run-Group the reports render against (e.g. "exhaustive", "guided", or a custom
# experiment name). Override per-invocation with --group=<name>.
group: "exhaustive"

# Output folder for generated HTML reports (relative to report root or absolute)
outputDir: "output"

# Default Model Selection config parameters
modelName: "Baseline + Rule of Law"
regionMappingFE: "regionmappingH12.csv"
includeLagged: false
adoptionThreshold: 0.5

# Dashboard configuration (cache root; reads index.json + models/ from here)
dashboardModelsDir: "output"
